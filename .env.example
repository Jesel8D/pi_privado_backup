# ============================================================
# TienditaCampus - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Ejecuta: bash devops/scripts/generate-secrets.sh
#    Esto llenará automáticamente los valores sensibles
# 3. NUNCA compartas ni subas el archivo .env a Git
# ============================================================

# ========================
# GENERAL
# ========================
COMPOSE_PROJECT_NAME=tc_stack_dev
NODE_ENV=development
TZ=America/Mexico_City

# ========================
# POSTGRESQL
# ========================
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_DB=tienditacampus
POSTGRES_USER=               # Generado por generate-secrets.sh
POSTGRES_PASSWORD=           # Generado por generate-secrets.sh

# ========================
# BACKEND (NestJS)
# ========================
BACKEND_PORT=3001
BACKEND_HOST_PORT=3001
BACKEND_BIND_IP=127.0.0.1
JWT_SECRET=                  # Generado por generate-secrets.sh
JWT_EXPIRATION=7d
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# (Opcional) Seed automático del admin al arrancar backend
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# ========================
# FRONTEND (Next.js)
# ========================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_PORT=3000

# ========================
# NGINX
# ========================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ========================
# BENCHMARKING (Google OAuth + BigQuery)
# ========================
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/benchmarking/auth/callback
GCP_PROJECT_ID=data-from-software
BIGQUERY_DATASET=benchmarking_warehouse
BIGQUERY_TABLE=daily_query_metrics
